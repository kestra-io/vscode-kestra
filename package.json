{
  "name": "kestra",
  "displayName": "Kestra",
  "description": "Kestra extension for VSCode to bring you smart autocompletion for your flows",
  "version": "0.0.0",
  "icon": "images/icon.png",
  "publisher": "kestra-io",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Other"
  ],
  "capabilities": {
    "virtualWorkspaces": true
  },
  "activationEvents": [
    "onFileSystem:kestra",
    "onLanguage:yaml"
  ],
  "main": "./dist/web/extension.js",
  "browser": "./dist/web/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kestra.schema.download",
        "title": "Download Kestra schema",
        "category": "Kestra"
      },
      {
        "command": "kestra.view.documentation",
        "title": "Open Kestra documentation",
        "category": "Kestra",
        "icon": "images/icons/kestra-documentation.svg"
      },
      {
        "command": "kestra.auth.signIn",
        "title": "Sign in",
        "category": "Kestra"
      },
      {
        "command": "kestra.auth.signOut",
        "title": "Sign out",
        "category": "Kestra"
      },
      {
        "command": "kestra.flow.run",
        "title": "Save and run flow",
        "category": "Kestra",
        "icon": "$(play)"
      },
      {
        "command": "kestra.flow.save",
        "title": "Save flow to Kestra",
        "category": "Kestra",
        "icon": "$(save)"
      },
      {
        "command": "kestra.flow.topology",
        "title": "Preview flow topology",
        "category": "Kestra",
        "icon": "$(type-hierarchy)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == yaml",
          "command": "kestra.schema.download"
        },
        {
          "when": "resourceLangId == yaml",
          "command": "kestra.flow.run"
        },
        {
          "when": "resourceLangId == yaml",
          "command": "kestra.flow.save"
        },
        {
          "when": "resourceLangId == yaml",
          "command": "kestra.flow.topology"
        }
      ],
      "editor/title": [
        {
          "when": "resourceLangId == yaml",
          "command": "kestra.flow.run",
          "group": "navigation"
        },
        {
          "when": "resourceLangId == yaml",
          "command": "kestra.flow.save",
          "group": "navigation"
        },
        {
          "when": "resourceLangId == yaml",
          "command": "kestra.flow.topology",
          "group": "navigation"
        },
        {
          "when": "resourceLangId == yaml",
          "command": "kestra.view.documentation",
          "alt": "Kestra documentation",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "kestra.flow.run",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorLangId == yaml"
      }
    ],
    "configuration": {
      "title": "Kestra",
      "properties": {
        "kestra.api.url": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Specify the api root url."
        },
        "kestra.api.tenant": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Tenant id for multi-tenant instances. Leave empty for instances that do not use tenant-scoped API routes."
        },
        "kestra.run.output": {
          "type": "string",
          "enum": [
            "panel",
            "logs"
          ],
          "enumDescriptions": [
            "Webview panel with status badge, per-task colors, and an execution link.",
            "Native log output channel with search, copy, and log-level filtering. Scales to large logs."
          ],
          "default": "panel",
          "description": "Where to show a flow run: the styled webview panel or the native log output channel."
        },
        "kestra.run.logLevel": {
          "type": "string",
          "enum": [
            "TRACE",
            "DEBUG",
            "INFO",
            "WARN",
            "ERROR"
          ],
          "default": "INFO",
          "description": "Minimum log level streamed when running a flow. Lower it to DEBUG or TRACE to see those logs."
        },
        "kestra.schema.match-path": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Specify a directory to your Kestra flows so that only YAML files from that directory will be validated against the Kestra API schema."
        }
      }
    }
  },
  "scripts": {
    "test": "mocha",
    "vscode:prepublish": "npm run package-web",
    "compile-web": "webpack",
    "watch-web": "webpack --watch",
    "package-web": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "run-in-browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. .",
    "vsix": "vsce package",
    "publish": "vsce publish"
  },
  "extensionDependencies": [
    "redhat.vscode-yaml"
  ],
  "devDependencies": {
    "@types/eslint": "^8.44.2",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.10.4",
    "@types/vscode": "^1.82.0",
    "@types/webpack-env": "^1.18.1",
    "@typescript-eslint/eslint-plugin": "^6.4.1",
    "@typescript-eslint/parser": "^6.4.1",
    "@vscode/test-web": "^0.0.68",
    "assert": "^2.0.0",
    "eslint": "^8.47.0",
    "mocha": "^10.8.2",
    "process": "^0.11.10",
    "ts-loader": "^9.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.6",
    "webpack": "^5.101.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "@types/markdown-it": "^13.0.6",
    "buffer": "^6.0.3",
    "css-loader": "^6.8.1",
    "cytoscape": "^3.34.0",
    "cytoscape-dagre": "^4.0.0",
    "markdown-it": "^13.0.2",
    "markdown-it-anchor": "^8.6.7",
    "markdown-it-container": "^3.0.0",
    "markdown-it-front-matter": "^0.2.3",
    "markdown-it-mark": "^3.0.1",
    "markdown-it-meta": "^0.0.1",
    "raw-loader": "^4.0.2",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "style-loader": "^3.3.3",
    "vue-loader": "^17.3.1",
    "yaml": "^2.3.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kestra-io/vscode-kestra.git"
  }
}
